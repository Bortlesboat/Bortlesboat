# This profile repo should only track the README, GitHub workflow, and generated profile cards.
# Local clone/release/worktree spillover belongs elsewhere and must not be staged here.
/*
!/.gitignore
!/README.md
!/case-studies.md
!/github-portfolio.md
!/github-contributions.md
!/.github/
!/.github/**
!/profile-summary-card-output/
!/profile-summary-card-output/**
